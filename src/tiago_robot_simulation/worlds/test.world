<?xml version="1.0" ?>
<sdf version="1.6">
<world name="rectangular_walls_world">
  <!-- Physics and Lighting -->
  <physics name="default_physics" type="ode">
    <gravity>0 0 -9.81</gravity>
  </physics>
  <light name="sun" type="directional">
    <cast_shadows>true</cast_shadows>
    <pose>0 0 100 0 0 0</pose>
    <diffuse>0.8 0.8 0.8 1</diffuse>
    <specular>0.5 0.5 0.5 1</specular>
    <direction>-0.5 -0.5 -1</direction>
  </light>

  <!-- Ground (unchanged) -->
  <model name="ground">
    <static>true</static>
    <link name="ground_link">
      <collision name="ground_collision">
        <geometry>
          <plane><normal>0 0 1</normal><size>200 200</size></plane>
        </geometry>
      </collision>
      <visual name="ground_visual">
        <geometry>
          <plane><normal>0 0 1</normal><size>200 200</size></plane>
        </geometry>
        <material>
          <ambient>0.4 0.4 0.4 1</ambient>
          <diffuse>0.6 0.55 0.5 1</diffuse>
        </material>
      </visual>
    </link>
  </model>

  <!-- ==================== Big Rectangular Walls with Texture ==================== -->
  <model name="big_rectangular_walls">
    <static>true</static>
    <pose>0 0 0 0 0 0</pose>
    <link name="walls_link">

      <!-- Front Wall -->
      <visual name="front_visual">
        <pose>0 -3 3 0 0 0</pose>
        <geometry><box><size>5 0.5 6</size></box></geometry>
        <material>
          <pbr>
            <metal>
              <albedo_map>file:///home/pika/bricks.jpg</albedo_map>  <!-- Change to your texture path -->
              <!-- Optional: roughness, metalness, etc. -->
              <roughness>0.8</roughness>
              <metalness>0.1</metalness>
            </metal>
          </pbr>
        </material>
      </visual>
      <collision name="front_collision">
        <pose>0 -3 3 0 0 0</pose>
        <geometry><box><size>5 0.5 6</size></box></geometry>
      </collision>

      <!-- Back Wall -->
      <visual name="back_visual">
        <pose>0 3 3 0 0 0</pose>
        <geometry><box><size>5 0.5 6</size></box></geometry>
        <material>
          <pbr>
            <metal>
              <albedo_map>file:///home/pika/bricks.jpg</albedo_map>  <!-- Change to your texture path -->
              <!-- Optional: roughness, metalness, etc. -->
              <roughness>0.8</roughness>
              <metalness>0.1</metalness>
            </metal>
          </pbr>
        </material>
      </visual>
      <collision name="back_collision">
        <pose>0 3 3 0 0 0</pose>
        <geometry><box><size>5 0.5 6</size></box></geometry>
      </collision>

      <!-- Left Wall -->
      <visual name="left_visual">
        <pose>-2.5 0 3 0 0 0</pose>
        <geometry><box><size>0.5 6 6</size></box></geometry>
        <material>
          <diffuse>1.0 1.0 1.0 1</diffuse>
          <specular>0.5 0.5 0.5 1</specular>
          <pbr>
            <metal>
              <albedo_map>materials/textures/wall_texture.png</albedo_map>
            </metal>
          </pbr>
        </material>
      </visual>
      <collision name="left_collision">
        <pose>-2.5 0 3 0 0 0</pose>
        <geometry><box><size>0.5 6 6</size></box></geometry>
      </collision>

      <!-- Right Wall -->
      <visual name="right_visual">
        <pose>2.5 0 3 0 0 0</pose>
        <geometry><box><size>0.5 6 6</size></box></geometry>
        <material>
          <pbr>
            <metal>
              <albedo_map>file:///home/pika/bricks.jpg</albedo_map>  <!-- Change to your texture path -->
              <!-- Optional: roughness, metalness, etc. -->
              <roughness>0.8</roughness>
              <metalness>0.1</metalness>
            </metal>
          </pbr>
        </material>
      </visual>
      <collision name="right_collision">
        <pose>2.5 0 3 0 0 0</pose>
        <geometry><box><size>0.5 6 6</size></box></geometry>
      </collision>

    </link>
  </model>

  <!-- Table (unchanged) -->
  <model name="table">
    <static>false</static>
    <pose>0 0 0.5 1.57 0 0</pose>
    <link name="table_link">
      <pose>0 0 0 0 0 0</pose>
      <visual name="table_visual">
        <geometry>
          <mesh>
            <uri>file:////home/pika/Downloads/1v2exin3byds-Tabel/Tabel/table.obj</uri>
            <scale>0.01 0.01 0.01</scale>
          </mesh>
        </geometry>
      </visual>
      <collision name="table_collision">
        <geometry>
          <mesh>
            <uri>file:////home/pika/Downloads/1v2exin3byds-Tabel/Tabel/table.obj</uri>
            <scale>0.01 0.01 0.01</scale>
          </mesh>
        </geometry>
      </collision>
    </link>
  </model>
  <model name="Big_Wall">
    <static>true</static>
    <pose>10 0.4 0.5 1.57 0 0</pose>
    <link name="wall_link">
      <pose>0 0 0 0 0 0</pose>
      <visual name="wall_visual">
        <geometry>
          <mesh>
            <uri>file:////home/pika/Downloads/22-3dkedr/BentWood_Planks.obj</uri>
            <!-- <scale>0.01 0.01 0.01</scale> -->
          </mesh>
        </geometry>
      </visual>
      <collision name="wall_collision">
        <geometry>
          <mesh>
            <uri>file:////home/pika/Downloads/22-3dkedr/BentWood_Planks.obj</uri>
            <scale>0.01 0.01 0.01</scale>
          </mesh>
        </geometry>
      </collision>
    </link>
  </model>
</world>
</sdf>